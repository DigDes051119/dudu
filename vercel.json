{
    "outputDirectory": ".",
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                { "key": "Access-Control-Allow-Origin", "value": "*" }
            ]
        },
        {
            "source": "/(.*).glb",
            "headers": [
                { "key": "Content-Type", "value": "model/gltf-binary" }
            ]
        }
    ]
}
